{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://cmx-core.dev/schemas/tasks.schema.json",
  "title": "SDD Tasks",
  "description": "Contrato de salida para fase de planificación de tareas",
  "type": "object",
  "required": ["phases", "total_tasks", "estimated_hours"],
  "additionalProperties": false,
  "properties": {
    "phases": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "order", "tasks"],
        "properties": {
          "name": { "type": "string" },
          "order": { "type": "integer", "minimum": 1 },
          "description": { "type": "string" },
          "tasks": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["id", "description", "type"],
              "properties": {
                "id": { "type": "string", "pattern": "^\\d+\\.\\d+" },
                "description": { "type": "string", "minLength": 10 },
                "type": { 
                  "type": "string",
                  "enum": ["implementation", "testing", "configuration", "documentation", "infrastructure"]
                },
                "status": { "type": "string", "enum": ["pending", "in_progress", "completed"], "default": "pending" },
                "files_affected": { "type": "array", "items": { "type": "string" } },
                "dependencies": { "type": "array", "items": { "type": "string" } },
                "estimated_minutes": { "type": "integer", "minimum": 5 }
              }
            }
          }
        }
      }
    },
    "total_tasks": {
      "type": "integer",
      "minimum": 1
    },
    "completed_tasks": {
      "type": "integer",
      "minimum": 0,
      "default": 0
    },
    "estimated_hours": {
      "type": "number",
      "minimum": 0.5
    },
    "priority_order": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Orden de ejecución recomendado"
    },
    "risks": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "task_id": { "type": "string" },
          "risk": { "type": "string" },
          "contingency": { "type": "string" }
        }
      }
    },
    "status": {
      "type": "string",
      "enum": ["planned", "in_progress", "completed"],
      "default": "planned"
    }
  }
}
