#!/bin/bash
# CMX CLI - Punto de entrada principal del sistema autónomo
# Uso: cmx <comando> [opciones]

set -e

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_ROOT="$SCRIPT_DIR"

# Scripts disponibles
BRAIN="$PROJECT_ROOT/brain.sh"
CHECK_ENV="$PROJECT_ROOT/scripts/check-environment.sh"
AI_SELECTOR="$PROJECT_ROOT/scripts/ai-selector.sh"
MEMORY_SAVE="$PROJECT_ROOT/scripts/memory-save.sh"
MEMORY_QUERY="$PROJECT_ROOT/scripts/memory-query.sh"
MEMORY_INIT="$PROJECT_ROOT/scripts/cmx-memories-init.sh"
BACKUP_SCRIPT="$PROJECT_ROOT/scripts/backup-memories.sh"
RESTORE_SCRIPT="$PROJECT_ROOT/scripts/restore-memories.sh"
CLEANUP_SCRIPT="$PROJECT_ROOT/scripts/cleanup-project.sh"

# Colores
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
NC='\033[0m'

# Help
show_help() {
    cat << EOF
CMX - Sistema Autónomo cmx-core v2.0
=====================================

Uso: cmx <comando> [opciones]

COMANDOS:
  task <descripción>     Ejecutar una tarea con el cerebro
  status                Ver estado del sistema
  list-ias              Listar IAs disponibles
  env-check             Verificar entorno
  memories [filtros]    Consultar memorias (SQLite)
  search <query>        Buscar en memorias (FTS5)
  cleanup <proyecto>    Cleanup post-proyecto
  init                  Inicializar cmx-memories (SQLite)
  backup                Crear backup de la base de datos
  restore <archivo>     Restaurar desde backup
  help                  Mostrar esta ayuda

OPCIONES:
  --mode manual|hybrid|autonomous  Nivel de autonomía (default: hybrid)
  --project <nombre>                Nombre del proyecto
  --context <texto>                 Contexto adicional

EJEMPLOS:
  cmx task "crear una API REST"
  cmx task "analizar el código" --mode autonomous
  cmx list-ias
  cmx memories cmx-core decision
  cmx search "test" cmx-core
  cmx backup
  cmx cleanup mi-proyecto

EOF
}

# Comandos
COMMAND="${1:-help}"
shift || true

case "$COMMAND" in
    task)
        TASK="$1"
        if [ -z "$TASK" ]; then
            echo "Error: Se requiere descripción de tarea"
            echo "Uso: cmx task <descripción>"
            exit 1
        fi
        shift
        
        # Parsear opciones adicionales
        MODE="hybrid"
        PROJECT="cmx-core"
        CONTEXT=""
        
        while [[ $# -gt 0 ]]; do
            case $1 in
                --mode)
                    # Validar que el modo sea válido
                    case "$2" in
                        manual|hybrid|autonomous)
                            MODE="$2"
                            ;;
                        *)
                            echo "Error: Modo inválido '$2'. Usos válidos: manual, hybrid, autonomous"
                            exit 1
                            ;;
                    esac
                    shift 2
                    ;;
                --project)
                    PROJECT="$2"
                    shift 2
                    ;;
                --context)
                    CONTEXT="$2"
                    shift 2
                    ;;
                *)
                    shift
                    ;;
            esac
        done
        
        "$BRAIN" --task "$TASK" --mode "$MODE" --project "$PROJECT" --context "$CONTEXT"
        ;;
    
    status)
        echo "=== CMX-CORE Status ==="
        echo ""
        echo "Proyecto: cmx-core"
        echo "Timestamp: $(date -Iseconds)"
        echo ""
        
        # Verificar memoria (SQLite)
        if [ -f "$PROJECT_ROOT/memories.db" ]; then
            MEM_COUNT=$(sqlite3 "$PROJECT_ROOT/memories.db" "SELECT COUNT(*) FROM memories;" 2>/dev/null || echo "0")
            DECISIONS=$(sqlite3 "$PROJECT_ROOT/memories.db" "SELECT COUNT(*) FROM memories WHERE type='decision';" 2>/dev/null || echo "0")
            SYNTHESIS=$(sqlite3 "$PROJECT_ROOT/memories.db" "SELECT COUNT(*) FROM memories WHERE type='synthesis';" 2>/dev/null || echo "0")
            FTS_INDEX=$(sqlite3 "$PROJECT_ROOT/memories.db" "SELECT COUNT(*) FROM memories_fts;" 2>/dev/null || echo "0")
            
            echo "Memorias (SQLite + FTS5):"
            echo "  Total: $MEM_COUNT"
            echo "  Decisiones: $DECISIONS"
            echo "  Síntesis: $SYNTHESIS"
            echo "  Índice FTS5: $FTS_INDEX"
        else
            echo "Memoria: No inicializada (ejecuta: cmx init)"
        fi
        echo ""
        
        # Verificar entorno
        echo "Entorno:"
        CHECK_OUTPUT=$("$CHECK_ENV" 2>/dev/null)
        # Extraer solo la parte JSON del output
        JSON_OUTPUT=$(echo "$CHECK_OUTPUT" | grep -A 100 "^{" | head -50)
        echo "$JSON_OUTPUT" | jq -r '.providers[] | "  \(.status): \(.models)"' 2>/dev/null || echo "  (error al obtener info)"
        echo ""
        echo "  Proveedores activos: $(echo "$JSON_OUTPUT" | jq -r '.available | join(", ")')" 2>/dev/null
        ;;
    
    list-ias)
        if [ -f "$PROJECT_ROOT/config/ai-registry.json" ]; then
            echo "=== IAs Registradas ==="
            echo ""
            jq -r '.ias | to_entries[] | 
                "\(.key): \(.value.status) (priority: \(.value.priority))\n  Capabilities: \((.value.capabilities | join(", ")))\n  Best for: \((.value.best_for | join(", ")))"' \
                "$PROJECT_ROOT/config/ai-registry.json" | while IFS= read -r line; do
                echo "  $line"
            done
        else
            echo "Error: ai-registry.json no encontrado"
            exit 1
        fi
        ;;
    
    env-check)
        "$CHECK_ENV" --strict
        ;;
    
    memories)
        PROJECT="${1:-cmx-core}"
        AGENT="${2:-}"
        TYPE="${3:-}"
        LIMIT="${4:-50}"
        
        "$MEMORY_QUERY" "$PROJECT" "$AGENT" "$TYPE" "$LIMIT"
        ;;
    
    cleanup)
        PROJECT="$1"
        if [ -z "$PROJECT" ]; then
            echo "Error: Se requiere nombre del proyecto"
            echo "Uso: cmx cleanup <proyecto>"
            exit 1
        fi
        if [ ! -f "$CLEANUP_SCRIPT" ]; then
            echo "Error: Script de cleanup no encontrado: $CLEANUP_SCRIPT"
            exit 1
        fi
        "$CLEANUP_SCRIPT" "$PROJECT"
        ;;
    
    init)
        "$MEMORY_INIT" "cmx-core"
        ;;
    
    backup)
        "$BACKUP_SCRIPT"
        ;;
    
    restore)
        BACKUP_FILE="$1"
        if [ -z "$BACKUP_FILE" ]; then
            echo "Error: Se requiere archivo de backup"
            echo "Uso: cmx restore <archivo-backup>"
            echo "Backups disponibles:"
            ls -1t "$PROJECT_ROOT/backups"/memories_*.db.gz 2>/dev/null | head -5 || echo "  No hay backups"
            exit 1
        fi
        "$RESTORE_SCRIPT" "$BACKUP_FILE"
        ;;
    
    search)
        QUERY="$1"
        if [ -z "$QUERY" ]; then
            echo "Error: Se requiere query de búsqueda"
            echo "Uso: cmx search <query> [proyecto] [tipo]"
            exit 1
        fi
        PROJECT="${2:-cmx-core}"
        TYPE="${3:-}"
        "$MEMORY_QUERY" --search "$QUERY" --project "$PROJECT" --type "$TYPE"
        ;;
    
    help|--help|-h)
        show_help
        ;;
    
    *)
        echo "Error: Comando desconocido '$COMMAND'"
        echo ""
        show_help
        exit 1
        ;;
esac