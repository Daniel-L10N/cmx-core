# CMX-CORE - Variables de Entorno (Template)
# ============================================
# Copia este archivo a .env y completa los valores
# NO SUBAS ARCHIVOS .env A GIT - usa .env.example como template

# OpenCode (incluye modelos gratuitos)
# No requiere API key adicional - los modelos gratis vienen con OpenCode

# Gemini CLI
# Ya instalado y configurado - se usa directamente via comando 'gemini'
# No necesita API key adicional

# OpenRouter (modelos gratuitos disponibles)
# Obtén tu API key en: https://openrouter.ai/settings
# OPENROUTER_API_KEY=tu-api-key-aqui

# OLLAMA (local, sin internet)
# Instalar: https://ollama.ai/
# ollama pull llama3.2