# =============================================================================
# Cognitive Stack - Environment Configuration
# =============================================================================
# This file defines all required environment variables for the application.
# Copy this file to .env.local for local development.
# NEVER commit actual secrets to version control!
# =============================================================================

# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------
DEBUG=true
NODE_ENV=development

# Application URL (for redirects, emails, etc.)
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXTAUTH_URL=http://localhost:3000

# NextAuth.js Configuration
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=your-nextauth-secret-key-here

# -----------------------------------------------------------------------------
# API / Backend
# -----------------------------------------------------------------------------
# Backend API URL (Django REST Framework)
NEXT_PUBLIC_API_URL=http://localhost:8000

# Backend CORS Configuration (Django)
ALLOWED_HOSTS=localhost,127.0.0.1
CORS_ALLOWED_ORIGINS=http://localhost:3000

# -----------------------------------------------------------------------------
# Database (PostgreSQL)
# -----------------------------------------------------------------------------
DATABASE_URL=postgres://postgres:password@localhost:5432/cognitive_stack_dev

# Alternative: Individual database settings (when not using DATABASE_URL)
DB_NAME=cognitive_stack_dev
DB_USER=postgres
DB_PASSWORD=password
DB_HOST=localhost
DB_PORT=5432

# -----------------------------------------------------------------------------
# Security - JWT Configuration
# -----------------------------------------------------------------------------
# Backend JWT Secret (Django SimpleJWT)
JWT_SECRET_KEY=your-jwt-secret-key-here
JWT_ALGORITHM=HS256

# Token Lifetimes (in SECONDS per SimpleJWT spec)
# Access Token: 15 minutes (900 seconds)
# Refresh Token: 7 days (604800 seconds)
ACCESS_TOKEN_LIFETIME=900
REFRESH_TOKEN_LIFETIME=604800

# Frontend Token Handling (HTTP-only cookies)
# These are NOT localStorage keys - they are cookie names
TOKEN_COOKIE_NAMES=accessToken,refreshToken

# Cookie Security Settings
COOKIE_SECURE=false  # Set to true in production (HTTPS)
COOKIE_SAME_SITE=strict

# -----------------------------------------------------------------------------
# Security - Password Hashing
# -----------------------------------------------------------------------------
# Bcrypt cost factor (12 = recommended minimum)
PASSWORD_BCRYPT_ROUNDS=12

# -----------------------------------------------------------------------------
# Rate Limiting
# -----------------------------------------------------------------------------
# Authentication rate limit (requests per window)
AUTH_RATE_LIMIT_MAX=5
AUTH_RATE_LIMIT_WINDOW=60  # seconds

# -----------------------------------------------------------------------------
# Email (Optional - for password reset)
# -----------------------------------------------------------------------------
# SMTP Configuration
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_USE_TLS=true
EMAIL_HOST_USER=your-email@example.com
EMAIL_HOST_PASSWORD=your-email-password
EMAIL_FROM=noreply@example.com

# -----------------------------------------------------------------------------
# External Services (Optional)
# -----------------------------------------------------------------------------
# Analytics
NEXT_PUBLIC_ANALYTICS_ID=

# Feature Flags
NEXT_PUBLIC_FEATURE_DARK_MODE=true
